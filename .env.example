# ============================================================
#  Environment configuration  /  环境变量配置
#  Copy to ".env" and fill in.  复制为 ".env" 并填写。
# ============================================================

# ---- Anthropic (Claude) : generation + LLM-as-judge ----
# 生成与评估均使用 Claude。无 key 时系统自动回退到确定性 mock(仅用于跑通流程/评估脚本)。
ANTHROPIC_API_KEY=

# ---- Voyage AI : embeddings + reranker ----
# 在线 embedding 与 rerank。无 key 时回退到本地哈希向量 mock。
VOYAGE_API_KEY=

# ---- Runtime ----
# 当任一 key 缺失时,是否允许 mock 回退(开发/评估默认 true;生产应设为 false 强制真实调用)
ALLOW_MOCK_FALLBACK=true

# 日志级别 DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# 配置文件路径
RAG_CONFIG=config/config.yaml
